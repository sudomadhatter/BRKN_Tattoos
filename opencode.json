{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "instructions": [
    "AGENTS.md",
    ".agents/rules/constitution.md",
    ".agents/rules/karpathy-guidelines.md",
    ".agents/rules/artifacts-always-first.md"
  ],
  "skills": {
    "paths": [".agents/skills"]
  },
  "permission": {
    "edit": {
      "_artifacts/**": "allow",
      "*": "ask"
    },
    "webfetch": "allow",
    "bash": {
      "*": "allow",
      "git push *": "ask",
      "git reset --hard *": "ask",
      "git commit *": "ask",
      "git rebase *": "ask",
      "rm *": "ask",
      "Remove-Item *": "ask",
      "del *": "ask",
      "taskkill *": "ask",
      "npm install *": "ask",
      "npm i *": "ask",
      "pip install *": "ask",
      "uv add *": "ask",
      "uv remove *": "ask",
      "firebase deploy *": "ask",
      "gcloud *": "ask"
    },
    "external_directory": {
      "*": "ask",
      "~/.config/opencode/**": "allow"
    }
  }
}
