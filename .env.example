# ============================================================================
# {{PROJECT_NAME}} — Environment Configuration
# ============================================================================
# INSTRUCTIONS:
# 1. Copy this file: cp .env.example auth_keys/.env
# 2. Fill in your actual values below
# 3. Never commit auth_keys/.env to git
# ============================================================================

# ============================================================================
# GOOGLE AI / GEMINI API
# ============================================================================
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================================================
# GOOGLE CLOUD PLATFORM (GCP)
# ============================================================================
# Your GCP Project ID (found in GCP Console)
GCP_PROJECT_ID=your-gcp-project-id

# Path to your service account JSON file
# Used for: Firebase/Firestore, Vertex AI Search
GOOGLE_APPLICATION_CREDENTIALS=auth_keys/service-account.json

# ============================================================================
# FIREBASE / FIRESTORE
# ============================================================================
# Uses GOOGLE_APPLICATION_CREDENTIALS above
# No additional config needed

# ============================================================================
# OPTIONAL: VERTEX AI SEARCH (RAG Data Stores)
# ============================================================================
# VERTEX_SEARCH_DB1_ID=your-datastore-id
# VERTEX_SEARCH_LOCATION=global

# ============================================================================
# OPTIONAL: DEVELOPMENT & DEBUGGING
# ============================================================================
# Enable debug mode (true/false)
DEBUG=false

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# FastAPI development mode
FASTAPI_RELOAD=true

# ============================================================================
# OPTIONAL: FRONTEND
# ============================================================================
# Backend API URL for frontend
VITE_API_URL=http://localhost:8000

# ============================================================================
# SERVICE ACCOUNT FILES CHECKLIST
# ============================================================================
# Ensure these files exist in auth_keys/ folder:
# ✓ auth_keys/service-account.json  (Main Firebase/Firestore/Vertex)
# ✓ auth_keys/.env                  (This file with real values)
#
# All files in auth_keys/ folder are gitignored automatically.
# ============================================================================
